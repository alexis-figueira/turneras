						array('TITLE' => 'ANULAR', 'ICON' => '<i class="fa-solid fa-trash-can fa-lg"></i>', 'FN' => 'Display_Turnos_Borrar', 'CLICK' => 'Display_Turnos_Borrar()', 'PERMISOS' => 'B', 'ROW_SELECTED' => TRUE),
						array('TITLE' => 'IMPRIMIR', 'ICON' => '<i class="fa-solid fa-print fa-lg"></i>', 'FN' => NULL, 'CLICK' => 'TablePrint(\'FICHA\', true)', 'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
						array('TITLE' => 'DESCARGAR', 'ICON' => '<i class="fa-regular fa-file-pdf fa-lg"></i>', 'FN' => 'Display_Descarga','CLICK' => 'Display_Descarga()',	'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
						array('TITLE' => 'ACTUALIZAR', 'ICON' => '<i class="fa-solid fa-rotate fa-lg"></i>', 'FN' => NULL, 'CLICK' => 'TableRefresh(\'FICHA\')', 'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
						array('TITLE' => 'VER TODO', 'ICON' => '<i class="fa-solid fa-eye fa-lg ToolShowHide"></i>', 'FN' => 'Display_Hide', 'CLICK' => 'Display_Hide()', 'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
