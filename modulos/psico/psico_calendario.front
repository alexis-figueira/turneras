unset($JS_TMP);

$JS_TMP = 'async function Display_Ver_Fecha(){';
	$JS_TMP .= '$("#Table_FICHA_advanced").val(JSON.stringify({CET_ID_CATEGORIA: $("#CALENDARIO_FORM #ID_CATEGORIA").val(), CTS_PROFESIONAL: $("#CALENDARIO_FORM #PROFESIONAL").val(), CFA_FECHA: $("#CALENDARIO_FORM #FECHA").val()}));';
	$JS_TMP .= 'TableLoad("FICHA");';
	$JS_TMP .= 'MODAL_TURNOS_INSTANCE.show();';
$JS_TMP .= '}';
array_push($FUNCTIONS,$JS_TMP);

$JS_TMP = 'async function Procesar_Periodo(method){';
	$JS_TMP .= 'let [year, month, day] = $("#CALENDARIO_FORM #PERIODO").val().split("-").map(Number);';
	$JS_TMP .= 'if(method == "add"){month += 1;}';
	$JS_TMP .= 'if(method == "less"){month -= 1;}';
	$JS_TMP .= 'if (month > 12) {';
		$JS_TMP .= 'year += 1;';
		$JS_TMP .= 'month = 1;';
	$JS_TMP .= '} else if (month < 1) {';
		$JS_TMP .= 'year -= 1;';
		$JS_TMP .= 'month = 12;';
	$JS_TMP .= '}';
	$JS_TMP .= '$("#CALENDARIO_FORM #PERIODO").val(year.toString().padStart(4, "0")+"-"+month.toString().padStart(2, "0")+"-01");';
	$JS_TMP .= 'Procesar_A_Ver();';
$JS_TMP .= '}';

$JS_TMP .= 'async function Procesar_A_Ver(){';
	$JS_TMP .= 'const response = await $.ajax({ url: "'.$LINK_BACK.'/Ver_Calendario3/", data: JSON.stringify( await FormDataPicker("CALENDARIO_FORM"))});';
	$JS_TMP .= '$("#DISPLAY_PERIODO").text(response.DISPLAY_PERIODO);';
	
	$JS_TMP .= '$("#TurneraCalendarBody").empty();';
	$JS_TMP .= '$.each(response.CALENDARIO, function(fila, dias) {';
		$JS_TMP .= 'let row = $("<tr></tr>");';
		$JS_TMP .= 'let maxDias = 7;';
		$JS_TMP .= 'let addedCells = 0;';
		$JS_TMP .= 'let primerDiaSemana = Math.min(...Object.keys(dias).map(Number));';
		$JS_TMP .= 'for (let i = 1; i < primerDiaSemana; i++) {';
			$JS_TMP .= 'row.append("<td></td>");';
			$JS_TMP .= 'addedCells++;';
		$JS_TMP .= '}';
		$JS_TMP .= '$.each(dias, function(dia, data) {';
			$JS_TMP .= 'let cell = $("<td></td>").text(data.FECHA);';			
			$JS_TMP .= 'if (data.CLICK != "") {';
				$JS_TMP .= 'if (data.CLICK == '.date("Y-m-d").') { cell.css("background-color", "#FFD93D"); }';
				$JS_TMP .= 'cell.attr("data-click", data.CLICK);';
			$JS_TMP .= '}';			
			$JS_TMP .= 'cell.attr("data-date", data.FECHA);';
			$JS_TMP .= 'row.append(cell);';
			$JS_TMP .= 'addedCells++;';
		$JS_TMP .= '});';
		$JS_TMP .= 'while (addedCells < maxDias) {';
			$JS_TMP .= 'row.append("<td></td>");';
			$JS_TMP .= 'addedCells++;';
		$JS_TMP .= '}';
		$JS_TMP .= '$("#TurneraCalendarBody").append(row);';
	$JS_TMP .= '});';
	$JS_TMP .= '';		
$JS_TMP .= '}';

$JS_TMP .= '$(document).off("click","#TurneraCalendarBody td").on("click", "#TurneraCalendarBody td", async function(){';
	$JS_TMP .= 'let dateValue = $(this).attr("data-click");';
	$JS_TMP .= 'if (dateValue != undefined) {';
		$JS_TMP .= '$("#CALENDARIO_FORM #FECHA").val(dateValue);';
		$JS_TMP .= 'let fecha = $("#CALENDARIO_FORM #FECHA").val().split("-");';
		$JS_TMP .= '$("#MODAL_TURNOS .nav-Ficha .subcardcard_header_btn").html(fecha[2]+"/"+fecha[1]);';
		$JS_TMP .= 'Display_Ver_Fecha();';
	$JS_TMP .= '}';
$JS_TMP .= '});';
array_push($FUNCTIONS,$JS_TMP);

$JS_TMP .= '$(document).ready(function(){';
	$JS_TMP .= 'Procesar_A_Ver();';	
$JS_TMP .= '});';
array_push($FUNCTIONS,$JS_TMP);

?>