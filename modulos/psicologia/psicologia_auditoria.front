	array('TITLE' => 'VER TURNOS',		'ICON' => '<i class="fa-solid fa-list fa-lg"></i>', 		'FN' => 'Display_A_Ver', 'CLICK' => 'Display_A_Ver()',	'PERMISOS' => 'C', 'ROW_SELECTED' => TRUE),
	array('TITLE' => 'ACTUALIZAR', 		'ICON' => '<i class="fa-solid fa-rotate fa-lg"></i>', 		'FN' => NULL, 					'CLICK' => 'TableRefresh(\'A\')', 	'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
);
