		$JS_TMP .= 'if( $("#Table_TURNOS_row").val() < 1){return;}';
		$JS_TMP .= 'const responseSF = await Swal.fire({';
			$JS_TMP .= 'title: "Estas por borrar el turno del "+$("#Row_TURNOS_" + $("#Table_TURNOS_row").val()).find("td").eq(0).html()+" a las "+$("#Row_TURNOS_" + $("#Table_TURNOS_row").val()).find("td").eq(1).html(),';
			$JS_TMP .= 'text: "Esta accion no se puede revertir!",';
			$JS_TMP .= 'icon: "warning",';
			$JS_TMP .= 'showCancelButton: true,';
			$JS_TMP .= 'confirmButtonText: "Si, borrar!",';
			$JS_TMP .= 'cancelButtonText: "No, cancelar!"';
		$JS_TMP .= '});';
		$JS_TMP .= 'if(responseSF.isConfirmed) {';
			$JS_TMP .= 'const response = await $.ajax({url: "'.$LINK_BACK.'/Procesar_Turnos_Borrar/", data: JSON.stringify({CEI_ID_AGENDA: $("#Table_A_row").val(),CEI_ID_PERIODO: $("#Table_PERIODO_row").val(),CEI_ID_HORARIO: $("#Table_TURNOS_row").val(), })});';
			$JS_TMP .= 'if(response.RESULTADO == "OK"){';
				$JS_TMP .= SF('OK');
				$JS_TMP .= 'await TableLoad("TURNOS");';				
			$JS_TMP .= '}else{';
				$JS_TMP .= 'if(response.MESSAGE != ""){'.SF('MSG', 'response.MESSAGE').'}';
				$JS_TMP .= 'else{'.SF('ERROR').'}';
			$JS_TMP .= '}';
		$JS_TMP .= '}';
	$JS_TMP .= '}';
	array_push($FUNCTIONS,$JS_TMP);
}
?>