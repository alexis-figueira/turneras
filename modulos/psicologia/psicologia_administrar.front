	$JS_TMP = 'async function Display_A_Principal(){';
		$JS_TMP .= 'FormErrorReset("A_PRINCIPAL_FORM");';
		$JS_TMP .= 'FormReset("A_PRINCIPAL_FORM");';
		$JS_TMP .= 'inicializarSelect2("#ID_CATEGORIA", "#MODAL_A_PRINCIPAL","'.$LINK_BACK.'/DL_Categorias/","Turnera", 0);';
		$JS_TMP .= 'inicializarSelect2("#ID_FERIADO", "#MODAL_A_PRINCIPAL","'.$LINK_BACK.'/DL_Feriados/","Feriados", 0);';
		$JS_TMP .= 'if($("#Table_A_row").val() > 0){';
			$JS_TMP .= 'const response = await $.ajax({ url: "'.$LINK_BACK.'/Ver_Agenda/", data: JSON.stringify({"CEI_ID_AGENDA": $("#Table_A_row").val()})});';
			$JS_TMP .= 'if(response.ID_AGENDA < 1){ return;}';

			$JS_TMP .= '$("#A_PRINCIPAL_FORM #ID_AGENDA").val(response.ID_AGENDA);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #ID_CATEGORIA").append(new Option(response.CATEGORIA, response.ID_CATEGORIA, true, true)).trigger("change");';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #PROFESIONAL").val(response.PROFESIONAL);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #EDAD_MINIMA").val(response.EDAD_MINIMA);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #EDAD_MAXIMA").val(response.EDAD_MAXIMA);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #PORTAL").val(response.PORTAL);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #SEXO_F").prop("checked", response.SEXO_F);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #SEXO_M").prop("checked", response.SEXO_M);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #SEXO_X").prop("checked", response.SEXO_X);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #ASUNTO").val(response.CORREO_SUBJ);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #MENSAJE").val(response.CORREO_MENS);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #CIERRE_DIAS").val(response.CIERRE_DIAS);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #CIERRE_HORARIO").val(response.CIERRE_HORARIO);';
			$JS_TMP .= '$("#A_PRINCIPAL_FORM #ID_FERIADO").append(new Option(response.FERIADO, response.ID_FERIADO, true, true)).trigger("change");';
		$JS_TMP .= '}';	
		$JS_TMP .= 'MODAL_A_PRINCIPAL_INSTANCE.show();';
	$JS_TMP .= '}';	
	array_push($FUNCTIONS,$JS_TMP);
	unset($JS_TMP);
	
	if($PP['A'] == 1){
		$JS_TMP = 'async function MODAL_A_PRINCIPAL_Procesar(){';
			$JS_TMP .= 'if($("#A_PRINCIPAL_FORM")[0].reportValidity()==false){return;}';
			$JS_TMP .= 'FormErrorReset("A_PRINCIPAL_FORM");';
			$JS_TMP .= 'const response = await $.ajax({url: "'.$LINK_BACK.'/Procesar_Agenda/",data: JSON.stringify(await FormDataPicker("A_PRINCIPAL_FORM"))});';
			$JS_TMP .= 'if(response.RESULTADO == "OK"){';
				$JS_TMP .= 'await TableLoad("A");';
				$JS_TMP .= 'MODAL_A_PRINCIPAL_INSTANCE.hide();';
				$JS_TMP .= SF('OK');
			$JS_TMP .= '}else{';
				$JS_TMP .= '';
				$JS_TMP .= 'if(response.MESSAGE != ""){'.SF('MSG', 'response.MESSAGE').'}';
				$JS_TMP .= 'else{'.SF('ERROR').'}';
			$JS_TMP .= '}';
		$JS_TMP .= '}';	
		array_push($FUNCTIONS,$JS_TMP);
		unset($JS_TMP);
	}
}

