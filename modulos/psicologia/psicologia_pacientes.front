<?php
$FILE_JS = 'default_v3';
$TABS['A'] =  array('ICON' => '<i class="fa-regular fa-address-book"></i>', 'TITLE' => 'Pacientes');

$TABLE['A']['COLUMNAS']			= array(
	array('COLUMNA' => 'Paciente'),
	array('COLUMNA' => 'Telefono'),
	array('COLUMNA' => 'Ultima', 'DB' => 'ULTIMO_TURNO'),
	array('COLUMNA' => 'Proxima', 'DB' => 'PROXIMO_TURNO'),
);
$TABLE['A']['AJAX_URL'] 		= $LINK_BACK.'/Listado_Pacientes';
$TABLE['A']['HERRAMIENTAS_NEW'] = array(
	array('TITLE' => 'ALTA PACIENTE', 	'ICON' => '<i class="fa-solid fa-user-plus fa-lg"></i>', 	'FN' => 'Display_Paciente', 	'CLICK' => 'Display_Paciente()', 		'PERMISOS' => 'A', 'ROW_SELECTED' => FALSE),
	array('TITLE' => 'INFO PACIENTE', 	'ICON' => '<i class="fa-solid fa-address-book fa-lg"></i>', 'FN' => 'Display_Ver_Paciente', 'CLICK' => 'Display_Ver_Paciente()',	'PERMISOS' => 'C', 'ROW_SELECTED' => TRUE),
	array('TITLE' => 'VER TURNOS',		'ICON' => '<i class="fa-solid fa-list fa-lg"></i>', 		'FN' => 'Display_A_Ver', 'CLICK' => 'Display_A_Ver()',	'PERMISOS' => 'C', 'ROW_SELECTED' => TRUE),
	array('TITLE' => 'BUSCAR', 			'ICON' => '<i class="fa-brands fa-searchengin fa-lg"></i>', 'FN' => 'Display_A_QuickSearch','CLICK' => 'Display_A_QuickSearch()',	'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
	
	// array('TITLE' => 'VER', 'ICON' => '<i class="fa-regular fa-eye fa-lg"></i>', 'FN' => 'Display_A_Ver', 'CLICK' => 'Display_A_Ver()', 'PERMISOS' => 'C', 'ROW_SELECTED' => TRUE),
	// array('TITLE' => 'ANULAR TURNO', 'ICON' => '<i class="fa-solid fa-calendar-xmark fa-lg"></i>', 'FN' => 'Display_A_Anular', 'CLICK' => 'Display_A_Anular()', 'PERMISOS' => 'A', 'ROW_SELECTED' => FALSE),
	// array('TITLE' => 'BUSCAR', 'ICON' => '<i class="fa-brands fa-searchengin fa-lg"></i>', 'FN' => 'Display_A_QuickSearch', 'CLICK' => 'Display_A_QuickSearch()', 'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
	array('TITLE' => 'ACTUALIZAR', 'ICON' => '<i class="fa-solid fa-rotate fa-lg"></i>', 'FN' => NULL, 'CLICK' => 'TableRefresh(\'A\')', 'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
);
$TABLE['A']['SETTING'] 			= array('ORDENAR' => "TRUE", 'ORDENAR_COL' => 1,'ORDENAR_METHOD' => 'DESC', 'DOBLE_CLICK' => 'Display_Ver_Paciente');
$TABLE['A']['QUICK_SEARCH']		= "Buscar Apellido y Nombre o DNI";

$MAIN = CreateMain($TABS, $TABLE);

if(in_array('Display_Paciente', $TABLE_FUNCTION)){
	unset($TMP);
	$TMP['MODAL']['ID']			= 'PACIENTE';
	$TMP['MODAL']['TITLE']		= 'Paciente';
	$TMP['MODAL']['SIZE']		= 'LG';
	
	$TMP['FOOTER']['SUBMIT'] 	= array('ID' => 'Guardar');
	$TMP['FOOTER']['CLOSE']		= array('ID' => 'Cerrar');
	
	$TMP['BODY'] = '<input type="hidden" id="AUTOFOCUS">';
	$TMP['BODY'] .= '<form id="'.$TMP['MODAL']['ID'].'_FORM" autocomplete="off">';
		$TMP['BODY'] .= CreateFormInput(array('ID' => 'id_paciente', 'TIPO' => 'hidden', 'VALIDATE' => 'CEI', 'REQUIRED' => TRUE, 'VALUE' => 0));
		$TMP['BODY'] .= '<div class="row">';
			$TMP['BODY'] .= '<div class="col-6 col-lg-4">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'apellido', 	'TIPO' => 'text', 	'VALIDATE' => 'CtS', 	'REQUIRED' => TRUE, 'MAXLENGTH' => 50, 'LOWERCASE' => TRUE));
			$TMP['BODY'] .= '</div>';
			$TMP['BODY'] .= '<div class="col-6 col-lg-4">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'nombre', 	'TIPO' => 'text', 	'VALIDATE' => 'CtS', 	'REQUIRED' => TRUE, 'MAXLENGTH' => 50, 'LOWERCASE' => TRUE));
			$TMP['BODY'] .= '</div>';
			$TMP['BODY'] .= '<div class="col-6 col-lg-4">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'dni', 		'TIPO' => 'number', 'VALIDATE' => 'CEI',	'REQUIRED' => TRUE,	'DECIMAL' => FALSE));
			$TMP['BODY'] .= '</div>';
			$TMP['BODY'] .= '<div class="col-6 col-lg-4">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'telefono', 	'TIPO' => 'text', 'VALIDATE' => 'CtS', 		'REQUIRED' => TRUE, 'MAXLENGTH' => 50, 'LOWERCASE' => TRUE));
			$TMP['BODY'] .= '</div>';			
			$TMP['BODY'] .= '<div class="col-12 col-lg-8">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'correo', 'TIPO' => 'correo', 'VALIDATE' => 'CIC', 'REQUIRED' => TRUE, 'LOWERCASE' => TRUE));
			$TMP['BODY'] .= '</div>';
			$TMP['BODY'] .= '<div class="col-6 col-lg-4">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'fecha', 'TIPO' => 'date', 'VALIDATE' => 'CFA', 'LABEL' => 'Fecha Nac.'));
			$TMP['BODY'] .= '</div>';
			$TMP['BODY'] .= '<div class="col-6 col-lg-3">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'localidad', 'TIPO' => 'text', 'VALIDATE' => 'CtS', 'MAXLENGTH' => 50, 'LOWERCASE' => TRUE));
			$TMP['BODY'] .= '</div>';
			$TMP['BODY'] .= '<div class="col-12 col-lg-5">';
				$TMP['BODY'] .= CreateFormInput(array('ID' => 'direccion', 'TIPO' => 'text', 'VALIDATE' => 'CtS', 'MAXLENGTH' => 50, 'LOWERCASE' => TRUE));
			$TMP['BODY'] .= '</div>';
		$TMP['BODY'] .= '</div>';
	$TMP['BODY'] .= '</form>';
	
	array_push($MODALS,CreateModal($TMP['MODAL'], $TMP['BODY'], $TMP['FOOTER']));
	array_push($VARS,"const MODAL_".$TMP['MODAL']['ID']."_INSTANCE = bootstrap.Modal.getOrCreateInstance('#MODAL_".$TMP['MODAL']['ID']."');");
	array_push($VARS,"const MODAL_".$TMP['MODAL']['ID']." = document.getElementById('MODAL_".$TMP['MODAL']['ID']."');");	
	unset($JS_TMP);
	
	$JS_TMP = 'async function Display_Paciente(){';
		$JS_TMP .= 'FormErrorReset("PACIENTE_FORM");';
		$JS_TMP .= 'FormReset("PACIENTE_FORM");';
		$JS_TMP .= '$("#MODAL_PACIENTE #AUTOFOCUS").val("APELLIDO");';
		$JS_TMP .= '$("#TITLE_PACIENTE").text("Nuevo paciente");';
		$JS_TMP .= '$("#MODAL_PACIENTE .FormBtnSubmit").prop("disabled", true);';
		$JS_TMP .= 'if($("#Table_A_row").val() >= 1){';
			$JS_TMP .= 'const response = await $.ajax({ url: "'.$LINK_BACK.'/Ver_Paciente/", data: JSON.stringify({"CEI_ID":$("#Table_A_row").val()})});';
			$JS_TMP .= '$("#PACIENTE_FORM #ID_PACIENTE").val(response.ID_PACIENTE);';
			$JS_TMP .= '$("#PACIENTE_FORM #APELLIDO").val(response.APELLIDO);';
			$JS_TMP .= '$("#PACIENTE_FORM #NOMBRE").val(response.NOMBRE);';
			$JS_TMP .= '$("#PACIENTE_FORM #DNI").val(response.DNI);';
			$JS_TMP .= '$("#PACIENTE_FORM #TELEFONO").val(response.TELEFONO);';
			$JS_TMP .= '$("#PACIENTE_FORM #CORREO").val(response.CORREO);';
			$JS_TMP .= '$("#PACIENTE_FORM #FECHA").val(response.FECHA);';
			$JS_TMP .= '$("#PACIENTE_FORM #LOCALIDAD").val(response.LOCALIDAD);';
			$JS_TMP .= '$("#PACIENTE_FORM #DIRECCION").val(response.DIRECCION);';
			$JS_TMP .= '$("#TITLE_PACIENTE").text("Modificar paciente");';
		$JS_TMP .= '}';
		$JS_TMP .= 'MODAL_PACIENTE_INSTANCE.show();';
	$JS_TMP .= '}';

 	$JS_TMP .= 'async function MODAL_PACIENTE_Procesar(){';
		$JS_TMP .= 'if($("#PACIENTE_FORM")[0].reportValidity()==false){return;}';
		$JS_TMP .= 'FormErrorReset("PACIENTE_FORM");';
		$JS_TMP .= 'if( $("#PACIENTE_FORM #DNI").val() == "" || $("#PACIENTE_FORM #DNI").val() > 99999999 || $("#PACIENTE_FORM #DNI").val() < 99999 ){'.SF('MSG','"Ingrese un DNI valido."').' return;}';
		$JS_TMP .= 'const response = await $.ajax({url: "'.$LINK_BACK.'/Procesar_Paciente/",data: JSON.stringify(await FormDataPicker("PACIENTE_FORM"))});';
		$JS_TMP .= 'if(response.RESULTADO == "OK"){';
			$JS_TMP .= 'await TableLoad("A");';
			$JS_TMP .= 'MODAL_PACIENTE_INSTANCE.hide();';
			$JS_TMP .= SF('OK', 'response.MESSAGE');
		$JS_TMP .= '}else{';
			$JS_TMP .= 'if(response.MESSAGE != ""){'.SF('MSG', 'response.MESSAGE').'}';
			$JS_TMP .= 'else{'.SF('ERROR').'}';
		$JS_TMP .= '}';		
	$JS_TMP .= '}';	
	array_push($FUNCTIONS,$JS_TMP);
}

if(in_array('Display_A_Ver', $TABLE_FUNCTION)){
	unset($TMP);
	$TMP['MODAL']['ID']			= 'FICHA';
	$TMP['MODAL']['TITLE']		= 'Ver Ficha';
	$TMP['MODAL']['SIZE']		= 'XL';
	
	$TMP['FOOTER']['CLOSE']		= array('ID' => 'Cerrar');
	
	$TMP['BODY'] = '<div class="card border-dark mx-auto mt-4 mb-0" style="width: 98%">';
		$TMP['BODY'] .= '<div class="card-header card-main  gradient_card rounded-2 text-light" id="subcard-main" style="--bs-bg-opacity: .95;">';
			$TMP['BODY'] .= '<div class="d-grid gap-2 d-flex justify-content-center">';
				$TMP['BODY'] .= '<ul class="nav nav-pills subtabs-buttons">';					
					$TMP['BODY'] .= '<li class="nav-item nav-Ficha">';
						$TMP['BODY'] .= '<button class="nav-link text-light mx-1" type="button" role="tab" aria-controls="FICHA" aria-selected="false">';
							$TMP['BODY'] .= '<i class="fa-solid fa-address-book fa-lg"></i> <div class="d-inline-block"><span class="d-none d-xl-block text-center subcardcard_header_btn">Ficha</span></div>';									
						$TMP['BODY'] .= '</button>';
					$TMP['BODY'] .= '</li>';
				$TMP['BODY'] .= '</ul>';
			$TMP['BODY'] .= '</div>';
		$TMP['BODY'] .= '</div>';
		$TMP['BODY'] .= '<div class="card text-center border border-0">';
			$TMP['BODY'] .= '<div class="card-body px-4 py-2 overflow-auto" id="subcardcard-body-main"> ';
				$TMP['BODY'] .= '<div class="tab-content subtabs-body">';			
					$TMP['BODY'] .= '<div class="tab-pane fade" role="tabpanel" aria-labelledby="FICHA" tabindex="1">';
						$SUBTABLE_FICHA['COLUMNAS']			= array(
							array('COLUMNA' => 'Fecha'),
							array('COLUMNA' => 'Horario'),
							array('COLUMNA' => 'Estado'),
						);
						$SUBTABLE_FICHA['AJAX_URL'] 		= $LINK_BACK.'/Listado_Turnos_Paciente';
						$SUBTABLE_FICHA['HERRAMIENTAS_NEW'] 	= array(
							array('TITLE' => 'AGREGAR', 'ICON' => '<i class="fa-solid fa-folder-plus fa-lg"></i>', 'FN' => 'Display_A_Turnos', 'CLICK' => 'TableRowClick(\'FICHA\',\'\');Display_A_Turnos()', 'PERMISOS' => 'A', 'ROW_SELECTED' => FALSE),
							array('TITLE' => 'ANULAR', 'ICON' => '<i class="fa-solid fa-trash-can fa-lg"></i>', 'FN' => 'Display_A_Turnos_Borrar', 'CLICK' => 'Display_A_Turnos_Borrar()', 'PERMISOS' => 'B', 'ROW_SELECTED' => TRUE),
							array('TITLE' => 'IMPRIMIR', 'ICON' => '<i class="fa-solid fa-print fa-lg"></i>', 'FN' => 'Display_A_Imprimir', 'CLICK' => 'Display_A_Imprimir()', 'PERMISOS' => 'A', 'ROW_SELECTED' => TRUE),
							array('TITLE' => 'ACTUALIZAR', 'ICON' => '<i class="fa-solid fa-rotate fa-lg"></i>', 'FN' => NULL, 'CLICK' => 'TableRefresh(\'FICHA\')', 'PERMISOS' => 'C', 'ROW_SELECTED' => FALSE),
						); 
						$SUBTABLE_FICHA['SETTING'] 			= array('ORDENAR' => "FALSE", 'ORDENAR_COL' => 1,'ORDENAR_METHOD' => 'DESC', 'DOBLE_CLICK' => 'Display_A_Turnos_Borrar');
						$TMP['BODY'] .= CreateMainTable('FICHA','Ficha', $SUBTABLE_FICHA, TRUE);
					$TMP['BODY'] .= '</div>';
				$TMP['BODY'] .= '</div>';
			$TMP['BODY'] .= '</div>';
		$TMP['BODY'] .= '</div>';
	$TMP['BODY'] .= '</div>';
	
	array_push($MODALS,CreateModal($TMP['MODAL'], $TMP['BODY'], $TMP['FOOTER']));
	array_push($VARS,"const MODAL_".$TMP['MODAL']['ID']."_INSTANCE = bootstrap.Modal.getOrCreateInstance('#MODAL_".$TMP['MODAL']['ID']."');");
	array_push($VARS,"const MODAL_".$TMP['MODAL']['ID']." = document.getElementById('MODAL_".$TMP['MODAL']['ID']."');");	
	unset($JS_TMP);
	
	$JS_TMP = 'async function Display_A_Ver(){';
		$JS_TMP .= 'if($("#Table_A_row").val() < 1){return;}';
		$JS_TMP .= '$("#MODAL_FICHA #Table_FICHA_advanced").val($("#Table_A_row").val());';
		$JS_TMP .= '$("#MODAL_FICHA #TITLE_FICHA").html("Afiliado: "+$("#Row_A_" + $("#Table_A_row").val()).find("td").eq(0).html());';
		$JS_TMP .= 'await TableLoad("FICHA");';
		$JS_TMP .= 'MODAL_FICHA_INSTANCE.show();';
	$JS_TMP .= '}';
	array_push($FUNCTIONS,$JS_TMP);
}











