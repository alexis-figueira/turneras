function create_pdf($TURNOS){
	/*= [NOMBRE] => TURNOS
		[CATEGORIA] => ODONTOLOGIA
		[PROFESIONAL] => PROFESIONAL 1
		//[AGENDA] => ODONTOLOGIA - PROFESIONAL 1
		[FECHA] => 08-08-2025
		[ROWS] => [0] => 
					[ST] => 
					[AFILIADO] => FIGUEIRA ALEXIS DAMIAN
					[DNI] => 39490719
					[NRO_OMINT] => 4929658500018
					[NRO_AFI] => 47257/1
					[HORA] => 10:00
	*/
	$TURNOS['AGENDA'] = $TURNOS['CATEGORIA']." - ".$TURNOS['PROFESIONAL'];
	$NORMAS_ISO = "DAS.CALIDAS.RE31-REV00";
	$MT = "100";
	$MTH = "60";
	$MB = "50";
	$MBH = "30";
	$formatterES = new NumberFormatter("es", NumberFormatter::SPELLOUT);
	$MAX_ROWS = 27;
	
	$STYLE = '<style>';
		$STYLE .= 	'body		{ size: A4;font-size: 12px;color: #333;font-family: "Roboto Condensed", sans-serif ; }'; /*  border: 1px solid red; */
		$STYLE .= 	'@page		{ size: A4 ; margin: '.($MT+30).'px 25px 30px 25px!important}';
		$STYLE .= 	'@page 		{ @bottom-center { content: element(footer); }}';
		$STYLE .= 	'.header 	{ position:fixed; top:-'.($MT+10).'px; left:0; right:0; width:100%; }';/* border: 1px solid green; */
		$STYLE .= 	'#footer 	{ width: 100%; text-align: center; font-size: 12px; height: 50px; margin: 30px 0px 0px 0px; }';
		$STYLE .= 	'.cabecera	{ background: #ececec;overflow: hidden;height: '.$MTH.'px; padding: 15px; border-radius: 5px; }'; /* border: 1px solid green; */
		$STYLE .= 	'.normas	{ position:absolute; top:20px; left:14px; width:170px; height:22px; line-height:20px; font-weight:700; border-radius:5px; text-align:center;}';
		$STYLE .= 	'.fecha		{ position:absolute; top:20px; right:14px; width:99px; height:22px; line-height:20px; font-weight:700; background:#bdbdbd; color:#333; border-radius:5px; text-align:center;}';
		$STYLE .= 	'.leyenda	{ margin-top: 8px; font-size: 10px; font-style: italic; color: #333 }';
		$STYLE .=  	'.label 	{ background: #bdbdbd; margin-top: 10px; font-weight: 700; border-radius: 5px; display: inline-block; padding: 5px 10px; text-align: center; line-height: 1.2; }';
		$STYLE .=  	'.label div { margin: 2px 0; white-space: nowrap; }';
		$STYLE .= 	'table 		{ width: 100%; font-size: 12px; border-collapse: collapse; }';
		$STYLE .= 	'td 		{ height: 35px; }';
		$STYLE .= 	'.pagina	{ position: absolute; bottom: +'.($MB-30).'px; left:0; right:0; width:100%; height: '.$MBH.'px;}';
	$STYLE .= '</style>';
	
	$HEADER = '<div class="header">';
		$HEADER .= '<div class="cabecera" align="center">';
			$HEADER .= '<div class="label" align="left">';
				$HEADER .= '<div>'.$TURNOS['AGENDA']." - ".$TURNOS['FECHA'].'</div>';
			$HEADER .= '</div>'; 
		$HEADER .= '</div>';
	$HEADER .= '</div>';
	$pages = array_chunk($TURNOS['ROWS'], $MAX_ROWS);
	$BODY = '';
		$BODY .= '<div class="divbody">';
			$BODY .= '<table style="color:#333; border-collapse: collapse;" border=1 width="100%">';
				$BODY .= '<thead>';
					$BODY .= '<tr>';
						$BODY .= '<th style="border: 1px solid #bdbdbd;border-collapse: collapse; width: 30%;" >AFLILIADO</th>';
						$BODY .= '<th style="border: 1px solid #bdbdbd;border-collapse: collapse; width: 15%;" >DNI</th>';
						$BODY .= '<th style="border: 1px solid #bdbdbd;border-collapse: collapse; width: 20%;" >NRO OMINT</th>';
						$BODY .= '<th style="border: 1px solid #bdbdbd;border-collapse: collapse; width: 15%;" >HORA</th>';
						$BODY .= '<th style="border: 1px solid #bdbdbd;border-collapse: collapse; width: 20%;" >FIRMA</th>';
					$BODY .= '</tr>';
				$BODY .= '</thead>'; 
				foreach ($pages as $pageIndex => $rows){
				$BODY .= '<tbody>';
					foreach($rows as $K ){
						$BODY .= '<tr>';
							$BODY .= '<td style="border: 1px solid #bdbdbd;border-collapse: collapse; text-align: center;">'.$K['AFILIADO'].'</td>';
							$BODY .= '<td style="border: 1px solid #bdbdbd;border-collapse: collapse; text-align: center;">'.$K['DNI'].'</td>';
							$BODY .= '<td style="border: 1px solid #bdbdbd;border-collapse: collapse; text-align: center;">'.$K['NRO_OMINT'].'</td>';
							$BODY .= '<td style="border: 1px solid #bdbdbd;border-collapse: collapse; text-align: center;">'.$K['HORA'].$K['ST'].'</td>';
							$BODY .= '<td style="border: 1px solid #bdbdbd;border-collapse: collapse; text-align: center;"></td>';
						$BODY .= '</tr>';
					}
				$BODY .= '</tbody>';
				}
			$BODY .= '</table><br/>';
		$BODY .= '</div>';

	$PDF = $STYLE.$HEADER.$BODY;
	$dompdf = new Dompdf();
	$dompdf->set_option('isHtml5ParserEnabled', true);
	$dompdf->set_option('isPhpEnabled', true);
	$dompdf->loadHtml($PDF, "UTF-8");
	$dompdf->setPaper("A4", "portrait");
	$dompdf->set_option('defaultMediaType', 'all');
	$dompdf->set_option('isFontSubsettingEnabled', true);
	$dompdf->render();
	$pdfOutput = $dompdf->output();
	$base64PDF = base64_encode($pdfOutput);
	return array(
		'file_base64' => $base64PDF,
		'filename' => $TURNOS['NOMBRE'].'.pdf'
	);
}
function create_pdf_ticket($TURNO){ // TIENE CAMBIOS
	list($dia, $mes, $año) = explode('-', $TURNO['FECHA']);
// AGREGO FILA NRO. AFILIADO 
// Y AGREGO LO DE LINEA XQ QUE ACEPTA TODAS LAS AGENDAS Y QUEDA RARO EL MENSAJE.
	if($TURNO['CATEGORIA'] == 'CHEQUEO ANUAL'){
		$LINEA_PROFESIONAL = "Establecimiento: ".$TURNO['PROFESIONAL'];
		$LINEA_HORARIO = "Hora: ".$TURNO['HORARIO'];
	}else{
		$LINEA_PROFESIONAL = "Profesional Dr.: ".$TURNO['PROFESIONAL'];
		$LINEA_HORARIO = "Consultorio Nº: ___ Hora: ".$TURNO['HORARIO'];
	}
	
	$HTML = '<html>';
		$HTML .= '<head>';
			$HTML .= '<meta charset="UTF-8">';
			$HTML .= '<style>';
				$HTML .= 'body			{ font-family:monospace; font-size:14px; margin:0; padding:0; }';
				$HTML .= '.ticket-container { width:70mm; margin:0 auto; padding:5px; }';
				$HTML .= '.ticket		{ border:1px solid black; padding:5px; }';
				$HTML .= '.title		{ font-weight:bold; text-align:center; margin-bottom:5px; font-size:14px; }';
				$HTML .= '.line 		{ margin-bottom:3px; }';
				$HTML .= '.firma 		{ margin-top:35px; border-top:1px solid black; text-align:center; font-size:11px; padding:2px 10px 0px 10px;}';
				$HTML .= '@media print 	{ ';
					$HTML .= '@page 		{ size:auto; margin:0; }';
					$HTML .= 'body			{ margin:0; padding:0; }';
				$HTML .= '}';
			$HTML .= '</style>';
		$HTML .= '</head>';
		$HTML .= '<body>';
			$HTML .= '<div class="ticket-container">';
				$HTML .= '<div class="ticket">';
					$HTML .= '<div class="title">DIRECCIÓN DE AYUDA SOCIAL PARA EL PERSONAL DEL CONGRESO DE LA NACIÓN</div>';
					$HTML .= '<div class="line">TURNO '.$TURNO['CATEGORIA'].'</div>';
					$HTML .= '<div class="line">Día: '.$dia.' Mes: '.$mes.' Año: '.$año.'</div>';
					// $HTML .= '<div class="line">Profesional Dr.: '.$TURNO['PROFESIONAL'].'</div>';
					// $HTML .= '<div class="line">Consultorio Nº: ___ Hora: '.$TURNO['HORARIO'].'</div>';
					$HTML .= '<div class="line">'.$LINEA_PROFESIONAL.'</div>';
					$HTML .= '<div class="line">'.$LINEA_HORARIO.'</div>';
					$HTML .= '<div class="line">Paciente: '.$TURNO['AFILIADO'].'</div>';
					$HTML .= '<div class="line">Nro. Afiliado: '.$TURNO['NRO_AFI'].'</div>';
					$HTML .= '<div class="firma">Firma del agente interviniente</div>';
				$HTML .= '</div>';
			$HTML .= '</div>';
		$HTML .= '</body>';
	$HTML .= '</html>';
	return $HTML;
}
function Estados($ESTADO, $METODO = NULL, $MOTIVO = NULL){
	if($METODO == 0){ $METODO = '-PORTAL';}else{ $METODO = '';}
	if($MOTIVO != NULL) { $INFO = ' - <i class="fa-solid fa-triangle-exclamation fa-lg" style="color:Orange" title="'.$MOTIVO.'"></i>'; }else{ $INFO = ''; }
	if($ESTADO == 0){ return 'ANULADO'.$METODO.' <i class="fa-solid fa-circle-xmark fa-lg" style="color:red"></i>'.$INFO;}
	elseif($ESTADO == 1){ return 'RESERVADO'.$METODO.' <i class="fa-solid fa-circle fa-lg" style="color:grey"></i>'.$INFO;}
	elseif($ESTADO == 10){ return 'AUSENTE <i class="fa-solid fa-circle-xmark fa-lg" style="color:purple"></i>'.$INFO;}
	elseif($ESTADO == 11){ return 'PRESENTE <i class="fa-solid fa-circle-check fa-lg" style="color:green"></i>'.$INFO;}
	else {return '';}
}
function generarSemanas($fechaInicio, $click = false) {
    $fecha = new DateTime($fechaInicio);
    $diasEnMes = $fecha->format('t');
    $mes = $fecha->format('m');
    $anio = $fecha->format('Y');
    $semanas = [];
    $semanaActual = 1;    
    for ($dia = 1; $dia <= $diasEnMes; $dia++) {
        $fecha->setDate($anio, $mes, $dia);
        $diaSemana = (int) $fecha->format('N');        
        if ($diaSemana >= 1 && $diaSemana <= 7) {
			if($click == true){$CLICK = $fecha->format('Y-m-d');}else{ $CLICK = '';}
            $semanas[$semanaActual][$diaSemana]['FECHA'] = (string)$dia;
            $semanas[$semanaActual][$diaSemana]['COLOR'] = '';
            $semanas[$semanaActual][$diaSemana]['TITLE'] = '';
            $semanas[$semanaActual][$diaSemana]['CLICK'] = $CLICK;
        }        
        if ($diaSemana == 7) {
            $semanaActual++;
        }
    }    
    return $semanas;
}
function Update_Fecha(&$calendario, $dia, $color, $title, $fecha) {
    foreach ($calendario as $semana => &$dias) {
        foreach ($dias as $diaSemana => &$datos) {
            if (isset($datos['FECHA']) && $datos['FECHA'] == $dia) {
                $datos['COLOR'] = $color;
                $datos['TITLE'] = $title;
                $datos['CLICK'] = $fecha;
                return true;
            }
        }
    }
    return false;
}
/* En caso de actualizacion de los template modificar portal de afiliados */ 
function TemplateAlta($AFILIADO,$TURNO, $TURNERA, $MENSAJE){
	$RETURN = '<div style="width:450px;border: 5px solid #27AE98; padding:20px;" align="center">';
		$RETURN .= '<img src="data:image/png;base64,'.$GLOBALS['CFG_LOGO_DAS'].'" alt="Logo"/>';
		$RETURN .= '<br><hr>';
		$RETURN .= '<h2 style="color:blue;"><b>Confirmacion de Turno</b></h2>';
		$RETURN .= '<p style="font-size:16px; text-align:justify;">Hola '.$AFILIADO.',</p>';
		$RETURN .= '<p style="font-size:16px; text-align:justify;">';
			$RETURN .= 'Tu turno ha sido confirmado. A continuación, te compartimos los detalles:</br>';
			$RETURN .= '- Fecha y hora: '.$TURNO.'</br>';
			$RETURN .= '- Motivo: '.$TURNERA.'</br>';
		$RETURN .= '</p>';
		$RETURN .= '<hr>';
		$RETURN .= '<h3 style="color:orange;">Información importante:</h3>';
		$RETURN .= '<p style="font-size:16px;text-align:left;">'.nl2br($MENSAJE).'</p>';
		$RETURN .= '<hr>';
		$RETURN .= '<p style="font-size:14px; text-align:justify;">';
			$RETURN .= 'Si no podés asistir, te pedimos que canceles tu turno con anticipación para brindarle la oportunidad a otro afiliado! Podés hacerlo a través de:<br/>';
			$RETURN .= '- Telefonicamente: 0810-222-0317<br/>';
			$RETURN .= '- Web: Portal de Autogestión<br/>';
		$RETURN .= '</p>';
		$RETURN .= '<p>Muchas Gracias,</p>';
		$RETURN .= '<p><b>DAS</b></p>';
	$RETURN .= '</div>';
	return $RETURN;
}
function TemplateCancelacion($AFILIADO,$TURNO, $TURNERA){
	$RETURN = '<div style="width:450px;border: 5px solid #27AE98; padding:20px;" align="center">';
		$RETURN .= '<img src="data:image/png;base64,'.$GLOBALS['CFG_LOGO_DAS'].'" alt="Logo"/>';
		$RETURN .= '<br><hr>';
		$RETURN .= '<h2 style="color:blue;"><b>Cancelacion de Turno</b></h2>';
		$RETURN .= '<p style="font-size:16px; text-align:justify;">Hola '.$AFILIADO.',</p>';
		$RETURN .= '<p style="font-size:16px; text-align:justify;">';
			$RETURN .= 'Tu turno ha sido cancelado. A continuación, te compartimos los detalles:</br>';
			$RETURN .= '- Fecha y hora: '.$TURNO.'</br>';
			$RETURN .= '- Turno: '.$TURNERA.'</br>';
		$RETURN .= '</p>';
		$RETURN .= '<p>Muchas Gracias,</p>';
		$RETURN .= '<p><b>DAS</b></p>';
	$RETURN .= '</div>';
	return $RETURN;
}



if($ROUTE_OPC == 'Listado_Turnos_Dia'){
	$RETURN['COUNT'] = 0;
	$RETURN['TOTAL'] = 0;
	$RETURN['PAGINAS'] = 1;
	$RETURN['ROWS'] = [];
	$RETURN['TITLE'] = '';
	if($PP['C'] != 1 || CIJE('CJS_ADVANCE')){EJE($RETURN);}
	if(!array_key_exists('CFA_FECHA',$sJ['CJS_ADVANCE']) || $sJ['CJS_ADVANCE']['CFA_FECHA'] == ''){EJE($RETURN);}
	$ARRAY_ORDER = array(1 => 'T.`horario_inicio` ASC');
	$FORM = LISTADO_QUERY($ARRAY_ORDER);
	$SEARCH = " WHERE T.`estado` > 0 AND T.`fecha`='".$sJ['CJS_ADVANCE']['CFA_FECHA']."'";
	$Que = QuerySelect("SELECT T.`id_turno`, CONCAT(P.`apellido`, ', ', P.`nombre`) AS 'paciente', T.`horario_inicio`,  T.`horario_fin`, T.`valor_sesion`, T.`estado` FROM ".$DBT['TURNOS']." T LEFT JOIN ".$DBT['PACIENTES']." P ON T.`id_paciente` = P.`id_paciente`". $SEARCH." ORDER BY ".$FORM['ORDENAR']." LIMIT ".$FORM['LIMIT']." ,".$FORM['ROWS']);
	while($Row = QueryFetch($Que)){
		$RETURN['COUNT']++;
		$TMP = [];
		$TMP['ID'] 						= $Row['id_turno'];
		$TMP['DATA']['PACIENTE'] 		= $Row['paciente'];
		$TMP['DATA']['HORARIO'] 		= Hora_Formato($Row['horario_inicio'])." - ".Hora_Formato($Row['horario_fin']);
		$TMP['DATA']['VALOR'] 			= "$".$Row['valor_sesion'];
		$TMP['DATA']['ESTADO'] 			= $Row['estado'];
		array_push($RETURN['ROWS'], $TMP);
		unset($TMP);
	}	
	
	$Que = QuerySelect("SELECT COUNT(*) AS 'total' FROM ".$DBT['TURNOS']." T LEFT JOIN ".$DBT['PACIENTES']." P ON T.`id_paciente` = P.`id_paciente`".$SEARCH);
	while($Row = QueryFetch($Que)){	
		$RETURN['TOTAL'] = $Row['total'];
		$RETURN['PAGINAS'] = ceil($RETURN['TOTAL']/$FORM['ROWS']);
	}
	EJE($RETURN);	
}
elseif($ROUTE_OPC == 'DL_Pacientes'){
	$RETURN['items'] =array();
	if($PP['C'] != 1){EJE($RETURN);}	
	$SEARCH = " WHERE `estado` = '1'";
	if(CIJE('CTS_SEARCH') !== TRUE){
		$terminos = explode(' ', $sJ['CTS_SEARCH']);
		$condiciones_busqueda = [];
		foreach ($terminos as $termino) {
			$t = trim($termino); 
			if (!empty($t)) {
				$condiciones_busqueda[] = "(`dni` LIKE '%".$t."%' OR `apellido` LIKE '%".$t."%' OR `nombre` LIKE '%".$t."%' OR `telefono` LIKE '%".$t."%')";
			}
		}
		if(count($condiciones_busqueda) > 0) { $SEARCH .= " AND (" . implode(" AND ", $condiciones_busqueda) . ")";}
	} 
	$Que = QuerySelect("SELECT `id_paciente`,  CONCAT( `apellido`, ', ', `nombre`) AS 'paciente' FROM ".$DBT['PACIENTES'].$SEARCH." ORDER BY `paciente`");
	while($Row = QueryFetch($Que)){
		$TMP = [];
		$TMP['ID']		= $Row['id_paciente'];
		$TMP['VALUE']	= $Row['paciente'];
		array_push($RETURN['items'], $TMP);
	}
	EJE($RETURN);
	
	
	
	
	
	
	$SEARCH = " WHERE C.`disponible`='1' AND A.`disponible`='1' AND C.`id_categoria` IN (".implode(",", $PERMISOS_C).")";
	if(CIJE('CTS_SEARCH') !== TRUE){ $SEARCH .= " AND C.`categoria` LIKE '%".$sJ['CTS_SEARCH']."%'";};
	$SEARCH .= " GROUP BY C.`id_categoria`";
	$Que = QuerySelect("SELECT C.`id_categoria`,C.`categoria` FROM ".$DBT['TURNERAS_PARAM_CATEGORIAS']." C JOIN ".$DBT['TURNERAS_AGENDAS']." A ON A.`id_categoria`=C.`id_categoria`".$SEARCH." ORDER BY `categoria` ASC", "QWE_PORTAL");
	while($Row = QueryFetch($Que)){
		$TMP = [];
		$TMP['ID']		= $Row['id_categoria'];
		$TMP['VALUE']	= $Row['categoria'];
		array_push($RETURN['items'], $TMP);
	}
	EJE($RETURN);
}
elseif($ROUTE_OPC == 'Procesar_Turno'){
	if($PP['A'] == 0){RJRE("Permiso denegado");}
	
	if(CIJE('CEI_ID_PACIENTE') === TRUE){RJRE("No se pudo procesar el identificador del afiliado.");};
	if(CIJE('CFA_FECHA_TURNO') === TRUE){RJRE("No se pudo procesar la fecha del turno.");};
	if(CIJE('CHA_HORA_INICIO') === TRUE){RJRE("No se pudo procesar el horario de inicio.");};
	if(CIJE('CHA_HORA_FINAL') === TRUE){RJRE("No se pudo procesar el horario final.");};
	if(CIJE('CEI_VALOR') === TRUE){RJRE("No se pudo procesar el horario final.");};
	if($sJ['CFA_FECHA_TURNO'] < date("Y-m-d")){ RJRE("Ingreso Manual. Fecha Invalida"); }
	if(strtotime($sJ['CHA_HORA_FINAL']) <= strtotime($sJ['CHA_HORA_INICIO'])){ RJRE("El horario final no puede ser mayor al incio de la sesión."); }


	$QuePaciente = QuerySelect("SELECT `id_paciente` FROM ".$DBT['PACIENTES']." WHERE `id_paciente`='".$sJ['CEI_ID_PACIENTE']."' AND `estado` = '1'");
	if(QueryNumRows($QuePaciente) < 1){ RJRE("El afiliado no es valido o no se encuentra activo."); }
	
	$QueHorario = QuerySelect("SELECT `id_turno`, `horario_inicio`,`horario_fin` FROM ".$DBT['TURNOS']." WHERE `fecha` = '".$sJ['CFA_FECHA_TURNO']."' AND (`horario_inicio` < '".$sJ['CHA_HORA_FINAL']."' AND `horario_fin` > '".$sJ['CHA_HORA_INICIO']."') AND `estado` != '0'");
	if(QueryNumRows($QueHorario) >= 1){
		while($RowHorario = QueryFetch($QueHorario)){
			RJRE("Hay un turno de ".$RowHorario['horario_inicio']." a ".$RowHorario['horario_fin']." que se superpone con el horario ingresado para el dia ".$sJ['CFA_FECHA_TURNO'].".");
		}
	}
	
	QueryInsert("INSERT INTO ".$DBT['TURNOS']."(`id_paciente`, `fecha`, `horario_inicio`, `horario_fin`, `valor_sesion`, `estado`, `reg_user`, `reg_fecha`) VALUES ('".$sJ['CEI_ID_PACIENTE']."','".$sJ['CFA_FECHA_TURNO']."','".$sJ['CHA_HORA_INICIO']."','".$sJ['CHA_HORA_FINAL']."','".$sJ['CEI_VALOR']."','1','".$C_USER['ID']."',NOW())");
	RJRO();
	
}
elseif($ROUTE_OPC == 'Ver_Calendario'){
	$RETURN['DISPLAY_PERIODO'] = '';
	if($PP['C'] != 1){EJE($RETURN);}
	if(CIJE('CFA_PERIODO') === TRUE){ EJE($RETURN);};
	
	$RETURN['DISPLAY_PERIODO'] = Fecha_Formato($sJ['CFA_PERIODO'], 'n');
	if(array_key_exists($RETURN['DISPLAY_PERIODO'], $CFG_CALENDARIO['MONTH'])){
		$RETURN['DISPLAY_PERIODO'] = $CFG_CALENDARIO['MONTH'][$RETURN['DISPLAY_PERIODO']]." ".Fecha_Formato($sJ['CFA_PERIODO'], "Y");;
	}	
	
	$RETURN['CALENDARIO'] = generarSemanas($sJ['CFA_PERIODO'], true);
	
	$TURNOS_POR_DIA = array();
	$QueFechas = QuerySelect("SELECT `fecha`, COUNT(*) AS 'turnos' FROM ".$DBT['TURNOS']." WHERE `estado` > 0 AND YEAR(`fecha`) = YEAR('".$sJ['CFA_PERIODO']."') AND MONTH(`fecha`) = MONTH('".$sJ['CFA_PERIODO']."') GROUP BY `fecha`");
	
	if(QueryNumRows($QueFechas) > 0){
		while($RowFechas = QueryFetch($QueFechas)){
			$TURNOS_POR_DIA[$RowFechas['fecha']] = $RowFechas['turnos'];
		}
	}
	
	$fechaInicio = new DateTime($sJ['CFA_PERIODO']);
	$diasEnMes = $fechaInicio->format('t');
	$mes = $fechaInicio->format('m');
	$anio = $fechaInicio->format('Y');

	for ($dia = 1; $dia <= $diasEnMes; $dia++) {
		$fechaActual = sprintf('%04d-%02d-%02d', $anio, $mes, $dia);
		
		$COLOR = 'VACIO';
		$TITLE = '';
		
		$cantidadTurnos = isset($TURNOS_POR_DIA[$fechaActual]) ? $TURNOS_POR_DIA[$fechaActual] : 0;

		if ($fechaActual < date("Y-m-d")) {
			$COLOR = 'PASADO';
			if ($cantidadTurnos > 0) {
				$TITLE = $cantidadTurnos.' turno(s)';
			}
		} elseif ($fechaActual == date("Y-m-d")) {
			$COLOR = 'HOY';
			$TITLE = 'HOY';
			if ($cantidadTurnos > 0) {
				$TITLE .= ' - '.$cantidadTurnos.' turno(s)';
			}
		} elseif ($cantidadTurnos > 0) {
			$COLOR = 'AGENDADO';
			$TITLE = $cantidadTurnos . ' turno(s)';
		}
		
		if($COLOR != ''){
			Update_Fecha($RETURN['CALENDARIO'], (string)$dia, $PALETA_COLORES[$COLOR], $TITLE, $fechaActual);
		}
	}
	
	EJE($RETURN);
}
else{
	EE("NO_SE_PUEDE_PROCESAR_LA_SOLICITUD");
}


$PERMISOS_C[] = 0;
$PERMISOS_A[] = 0;
$PERMISOS_B[] = 0;
$PERMISOS_M[] = 0;
$PERMISOS_E[] = 0;
$QuePermisos = QuerySelect("SELECT `id_categoria`,CASE WHEN `permiso` LIKE '%C%' THEN 1 ELSE 0 END AS 'C', CASE WHEN `permiso` LIKE '%A%' THEN 1 ELSE 0 END AS 'A', CASE WHEN `permiso` LIKE '%B%' THEN 1 ELSE 0 END AS 'B', CASE WHEN `permiso` LIKE '%M%' THEN 1 ELSE 0 END AS 'M', CASE WHEN `permiso` LIKE '%E%' THEN 1 ELSE 0 END AS 'E' FROM ".$DBT['PERMISOS_TURNERA']." WHERE `id_usuario`='".$C_USER['ID']."' AND (permiso LIKE '%C%' OR permiso LIKE '%A%' OR permiso LIKE '%B%' OR permiso LIKE '%E%')");
if(QueryNumRows($QuePermisos) > 0 ){
	while($RowPermisos = QueryFetch($QuePermisos)){
		if($RowPermisos['C'] == 1){ $PERMISOS_C[] = $RowPermisos['id_categoria'];}
		if($RowPermisos['A'] == 1){ $PERMISOS_A[] = $RowPermisos['id_categoria'];}
		if($RowPermisos['B'] == 1){ $PERMISOS_B[] = $RowPermisos['id_categoria'];}
		if($RowPermisos['M'] == 1){ $PERMISOS_M[] = $RowPermisos['id_categoria'];}
		if($RowPermisos['E'] == 1){ $PERMISOS_E[] = $RowPermisos['id_categoria'];}
	}
}
if($ROUTE_OPC == 'DL_Agendas'){
	$RETURN['items'] =array();
	if($PP['C'] != 1){EJE($RETURN);}	
	$SEARCH = " WHERE C.`disponible`='1' AND A.`disponible`='1' AND C.`id_categoria` IN (".implode(",", $PERMISOS_C).") AND  C.`sobreturnos`=0";
	if(CIJE('CTS_SEARCH') !== TRUE){ $SEARCH .= " AND (C.`categoria` LIKE '%".$sJ['CTS_SEARCH']."%' OR A.`profesional` LIKE '%".$sJ['CTS_SEARCH']."%' OR CONCAT(C.`categoria`,if(A.`profesional` != 'GENERAL',CONCAT(' - ',A.`profesional`),'')) LIKE '%".$sJ['CTS_SEARCH']."%')";};
	$Que = QuerySelect("SELECT A.`id_agenda`, CONCAT(C.`categoria`,if(A.`profesional` != 'GENERAL',CONCAT(' - ',A.`profesional`),'')) AS 'agenda' FROM ".$DBT['TURNERAS_AGENDAS']." A JOIN ".$DBT['TURNERAS_PARAM_CATEGORIAS']." C ON A.`id_categoria`=C.`id_categoria`".$SEARCH." ORDER BY C.`categoria` ASC", "QWE_PORTAL");
	while($Row = QueryFetch($Que)){
		$TMP = [];
		$TMP['ID']		= $Row['id_agenda'];
		$TMP['VALUE']	= $Row['agenda'];
		array_push($RETURN['items'], $TMP);
	}
	EJE($RETURN);
}
elseif($ROUTE_OPC == 'DL_Categorias'){
	$RETURN['items'] =array();
	if($PP['C'] != 1){EJE($RETURN);}	
	$SEARCH = " WHERE C.`disponible`='1' AND A.`disponible`='1' AND C.`id_categoria` IN (".implode(",", $PERMISOS_C).")";
	if(CIJE('CTS_SEARCH') !== TRUE){ $SEARCH .= " AND C.`categoria` LIKE '%".$sJ['CTS_SEARCH']."%'";};
	$SEARCH .= " GROUP BY C.`id_categoria`";
	$Que = QuerySelect("SELECT C.`id_categoria`,C.`categoria` FROM ".$DBT['TURNERAS_PARAM_CATEGORIAS']." C JOIN ".$DBT['TURNERAS_AGENDAS']." A ON A.`id_categoria`=C.`id_categoria`".$SEARCH." ORDER BY `categoria` ASC", "QWE_PORTAL");
	while($Row = QueryFetch($Que)){
		$TMP = [];
		$TMP['ID']		= $Row['id_categoria'];
		$TMP['VALUE']	= $Row['categoria'];
		array_push($RETURN['items'], $TMP);
	}
	EJE($RETURN);
}
elseif($ROUTE_OPC == 'DL_Horarios'){
	$RETURN['items'] =array();
	if($PP['C'] != 1){EJE($RETURN);}
	if(CIJE('CET_ID_CATEGORIA') === TRUE){EJE($RETURN);};
	if(CIJE('CFA_FECHA') === TRUE){EJE($RETURN);};
	if(!in_array($sJ['CET_ID_CATEGORIA'],$PERMISOS_C)){EJE($RETURN);}
	
	$AGENDA = array();
	$QueAgendas = QuerySelect("SELECT `id_agenda`,`cierre_dia`,`cierre_horario`,`id_feriados` FROM ".$DBT['TURNERAS_AGENDAS']." WHERE `id_categoria`='".$sJ['CET_ID_CATEGORIA']."' AND `disponible`='1'","QWE_PORTAL");
	if(QueryNumRows($QueAgendas) < 1){EJE($RETURN);};
	while($RowAgendas = QueryFetch($QueAgendas)){
		$AGENDA[$RowAgendas['id_agenda']]['CIERRE_DIA'] = $RowAgendas['cierre_dia'];
		$AGENDA[$RowAgendas['id_agenda']]['CIERRE_HORARIO'] = $RowAgendas['cierre_horario'];
		$AGENDA[$RowAgendas['id_agenda']]['ID_FERIADOS'] = $RowAgendas['id_feriados'];
	}
	
	$Que = QuerySelect("CALL ".ZXS_PORTAL_T.".`SP_Turnera_Calendario`('".$sJ['CFA_FECHA']."','".$sJ['CTS_PROFESIONAL']."','".$sJ['CET_ID_CATEGORIA']."','DIA');","QWE_PORTAL");
	while($Row = QueryFetch($Que)){
		if($Row['turnos'] > $Row['turnos_tomados'] && $Row['feriado'] == 0 && $Row['disponible'] == 1){
			$TMP = [];
			$TMP['ID']		= $Row['id_agenda'].'_'.Hora_Formato($Row['hora']);
			$TMP['VALUE']	= Hora_Formato($Row['hora']).($sJ['CTS_PROFESIONAL'] == 0 ? " - ".$Row['profesional'] : "");
			array_push($RETURN['items'], $TMP);
		}
	}
	EJE($RETURN);
}
elseif($ROUTE_OPC == 'DL_Profesionales'){
	$RETURN['items'] =array();
	$TMP = [];
	$TMP['ID']		= 0;
	$TMP['VALUE']	= 'VER TODAS';
	array_push($RETURN['items'], $TMP);
	if($PP['C'] != 1){EJE($RETURN);}
	if(CIJE('CET_ID_CATEGORIA') === TRUE){EJE($RETURN);};
	if(!in_array($sJ['CET_ID_CATEGORIA'],$PERMISOS_C)){EJE($RETURN);}
	$SEARCH = " WHERE `disponible`='1' AND `id_categoria`='".$sJ['CET_ID_CATEGORIA']."'";
	if(CIJE('CTS_SEARCH') !== TRUE){ $SEARCH .= " AND `profesional` LIKE '%".$sJ['CTS_SEARCH']."%'";};
	$Que = QuerySelect("SELECT `id_agenda`,`profesional` FROM ".$DBT['TURNERAS_AGENDAS']." ".$SEARCH." ORDER BY `profesional` ASC","QWE_PORTAL");
	while($Row = QueryFetch($Que)){
		$TMP = [];
		$TMP['ID']		= $Row['id_agenda'];
		$TMP['VALUE']	= $Row['profesional'];
		array_push($RETURN['items'], $TMP);
	}
	EJE($RETURN);
}
elseif($ROUTE_OPC == 'Download_Turnos'){ //TIENE CAMBIOS
	if($PP['C'] != 1 || CIJE('CJS_DATA')){RJRE("Ocurrió un error al procesar la descarga.");}
	if(
		!array_key_exists('CET_ID_CATEGORIA',$sJ['CJS_DATA']) || $sJ['CJS_DATA']['CET_ID_CATEGORIA'] == '' || 
		!array_key_exists('CTS_PROFESIONAL',$sJ['CJS_DATA']) || $sJ['CJS_DATA']['CTS_PROFESIONAL'] == '' || 
		!array_key_exists('CFA_FECHA',$sJ['CJS_DATA']) || $sJ['CJS_DATA']['CFA_FECHA'] == ''

	){RJRE("Ocurrió un error al procesar la descarga.");}
	$TURNOS = [];
	$TURNOS['NOMBRE']	= "TURNOS";
	$TURNOS['FECHA']	= fecha_formato($sJ['CJS_DATA']['CFA_FECHA']);
	$TURNOS['ROWS'] = [];
	
	if(!in_array($sJ['CJS_DATA']['CET_ID_CATEGORIA'], $PERMISOS_C)){ EJE($RETURN); }
	$ID_CATEGORIA[] = $sJ['CJS_DATA']['CET_ID_CATEGORIA'];
	$ID_AGENDA[] = $sJ['CJS_DATA']['CTS_PROFESIONAL'];
	/* BUSCAR SOBRETURNOS */
//NO INCLUYE LA AGENDA SOBRETURNOS --- TERMINA CREANDO UN IN(".implode(',',$ID_CATEGORIA).") QUE HACE --> IN (1,1) [BUSCA LA AGENDA PADRE NADA MAS]
	$QueST = QuerySelect("SELECT TA.`id_agenda`, TA.`id_categoria`, TA.`profesional`, PTC.`categoria` FROM ".$DBT['TURNERAS_AGENDAS']." TA JOIN ".$DBT['TURNERAS_PARAM_CATEGORIAS']." PTC ON PTC.`id_categoria`=TA.`id_categoria` LEFT JOIN ".$DBT['TURNERAS_PARAM_CATEGORIAS']." PTCH ON PTCH.sobreturnos='1' AND PTCH.`sobreturnos_padre`=PTC.id_categoria LEFT JOIN ".$DBT['TURNERAS_AGENDAS']." TH ON TH.id_categoria=PTCH.id_categoria AND TH.profesional=TA.profesional WHERE TA.`id_categoria`='".$sJ['CJS_DATA']['CET_ID_CATEGORIA']."' AND TA.`id_agenda`='".$sJ['CJS_DATA']['CTS_PROFESIONAL']."'","QWE_PORTAL");
	if(QueryNumRows($QueST) >0 ){
		while($RowST = QueryFetch($QueST)){
			if(in_array($RowST['id_categoria'], $PERMISOS_C)){
				$ID_CATEGORIA[] = $RowST['id_categoria'];
				// $TURNOS['AGENDA']	= $RowST['categoria']." - ".$RowST['profesional'] ;
				$TURNOS['CATEGORIA']	= $RowST['categoria'];
				$TURNOS['PROFESIONAL'] 	= $RowST['profesional'];
				$ID_AGENDA[] 			= $RowST['id_agenda'];
			}
		}
	}

	$ARRAY_ORDER = array(1 => 'T.`horario` ASC');
	$FORM = LISTADO_QUERY($ARRAY_ORDER); 
	$SEARCH = "WHERE A.`id_categoria` IN (".implode(',',$ID_CATEGORIA).") AND T.`id_agenda` IN (".implode(',',$ID_AGENDA).") AND T.`fecha`='".$sJ['CJS_DATA']['CFA_FECHA']."' AND T.`estado` >= '1'";
/*AGREGO ["-" AS NRO_AFI] Y [T.`celular`] A LA CONSULTA*/
	$Que = QuerySelect("SELECT IF(T.`id_agenda` = '".$sJ['CJS_DATA']['CTS_PROFESIONAL']."','TURNO','SOBRETURNO') AS 'tipo', T.`id_persona`,'-' AS 'afiliado','-' AS 'dni', '-' AS 'nro_omint', '-' AS 'nro_afi', T.`celular`,T.`horario` AS 'hora',T.`estado` FROM ".$DBT['TURNERAS_TURNOS']." T JOIN ".$DBT['TURNERAS_AGENDAS']." A ON T.`id_agenda`= A.`id_agenda` ". $SEARCH." ORDER BY ".$FORM['ORDENAR']." LIMIT ".$FORM['LIMIT']." ,".$FORM['ROWS'],"QWE_PORTAL");
	$MAP_ID_PERSONA = array();
	if(QueryNumRows($Que) < 1){RJRE("No hay turnos pendientes para esta fecha.");}
	while($Row = QueryFetch($Que)){
		$TMP = [];
		// $Row['tipo'] == 'SOBRETURNO' ? $TMP['ST'] = ' (ST)' : $TMP['ST'] = '' ; // PARA DSPS AGREGARLO AL HORARIO O ALGUNA VARIABLE CUANDO MUESTRO EL PDF -> $VAR.$VAR['ST'] --> 10.00(ST)
		$TMP['AFILIADO'] 		= $Row['id_persona'] == 0 ? 'TURNO BLOQUEADO' :$Row['afiliado'];
		$TMP['DNI'] 			= $Row['dni'];
		$TMP['NRO_OMINT']	 	= $Row['nro_omint'];
/*AGR*/	$TMP['NRO_AFI']			= $Row['nro_afi']; 
/*AGR*/	$TMP['TELEFONO'] 		= $Row['celular'];
		$TMP['HORA'] 			= Hora_Formato($Row['hora']);
		$index = count($TURNOS['ROWS']);
		array_push($TURNOS['ROWS'], $TMP);
		unset($TMP);
		if (!empty($Row['id_persona'])) {
			$MAP_ID_PERSONA[$Row['id_persona']][] = $index;
		}
	}
	if(count($MAP_ID_PERSONA) > 0){
/*AGREGO AFI_NRO Y AFI_BARRA A LA CONSULTA*/
		$Que = QuerySelect("SELECT P.`id_persona`, CONCAT(P.`apellido`,' ',P.`nombre`) AS 'afiliado', P.`dni`, `nro_omint`, P.`afi_nro`, P.`afi_barra`, C.`celular`, C.`mail`, P.`estado` FROM ".$DBT['PADRON_PERSONAS']." P LEFT JOIN ".$DBT['PADRON_CONTACTO']." C ON P.`id_persona`=C.`id_persona` WHERE P.`id_persona` IN(".implode(',', array_keys($MAP_ID_PERSONA)).")");
		while($Row = QueryFetch($Que)){	
			foreach ($MAP_ID_PERSONA[$Row['id_persona']] as $index) {
				$TURNOS['ROWS'][$index]['AFILIADO'] = $Row['afiliado'];
				$TURNOS['ROWS'][$index]['DNI'] 		= $Row['dni'];
				$TURNOS['ROWS'][$index]['NRO_OMINT']= $Row['nro_omint'];
/*AGREGO*/		$TURNOS['ROWS'][$index]['NRO_AFI'] 	= $Row['afi_nro']."/".$Row['afi_barra'];
			}
		}
	}
	$File = create_pdf2($TURNOS);
	if($File['filename'] != 'Error.xlsx' && $File['file_base64'] != ''){
		$RETURN['RESULTADO'] = 'OK';
		$RETURN['BASE64'] = $File['file_base64'];
		$RETURN['ARCHIVO'] = $File['filename'];
		EJE($RETURN);
	}
	RJRE();
}
elseif($ROUTE_OPC == 'Listado_Afiliado'){
	$RETURN['COUNT'] = 0;
	$RETURN['TOTAL'] = 0;
	$RETURN['PAGINAS'] = 1;
	$RETURN['ROWS'] = [];
	if($PP['C'] != 1){EJE($RETURN);}
	$ARRAY_ORDER = array(1 => '`afiliado` {METHOD}', 2 => '`dni` {METHOD}', 3 => '`cuil` {METHOD}', 4 => '`fecha_nacimiento` {METHOD}', 4 => '`sexo` {METHOD}');
	$FORM = LISTADO_QUERY($ARRAY_ORDER);
	if($FORM['SEARCH'] == NULL){EJE($RETURN);}
	$SEARCH = "WHERE (P.`dni`='".$FORM['SEARCH']."' AND P.`dni`>0) OR (P.`cuil`='".$FORM['SEARCH']."' AND P.`cuil` > 0) OR CONCAT(P.`apellido`,' ',P.`nombre`) LIKE '%".$FORM['SEARCH']."%'";
	$Que = QuerySelect("SELECT P.`id_persona`, CONCAT(P.`nombre`,' ',P.`apellido`) AS 'afiliado', P.`dni`, P.`cuil`, CONCAT(VA.`tipo`,' - ',VA.`subtipo`) AS 'afiliacion', P.`fecha_nacimiento`, P.`sexo`,P.`estado` FROM ".$DBT['PADRON_PERSONAS']." P LEFT JOIN ".$DBT['V_PADRON_ACTUAL']." VA ON P.`id_persona`=VA.`id_persona`". $SEARCH." ORDER BY ".$FORM['ORDENAR']." LIMIT ".$FORM['LIMIT']." ,".$FORM['ROWS']);
	while($Row = QueryFetch($Que)){
		$RETURN['COUNT']++;
		$TMP = [];
		$TMP['ID'] 						= $Row['id_persona'];
		$TMP['DATA']['AFILIADO'] 		= $Row['afiliado'];
		$TMP['DATA']['DNI'] 			= $Row['dni'];
		$TMP['DATA']['FECHA'] 			= Fecha_Formato($Row['fecha_nacimiento']);
		$TMP['DATA']['EDAD'] 			= Calcular_Edad($Row['fecha_nacimiento']);
		$TMP['DATA']['SEXO'] 			= $Row['sexo'];
		$TMP['DATA']['ESTADO'] 			= AfiliadoGetCoberturaIcon($Row['estado']);
		array_push($RETURN['ROWS'], $TMP);
		unset($TMP);
	}
	$Que = QuerySelect("SELECT COUNT(*) AS 'total' FROM ".$DBT['PADRON_PERSONAS']." P LEFT JOIN ".$DBT['V_PADRON_ACTUAL']." VA ON P.`id_persona`=VA.`id_persona`". $SEARCH);
	while($Row = QueryFetch($Que)){	
		$RETURN['TOTAL'] = $Row['total'];
		$RETURN['PAGINAS'] = ceil($RETURN['TOTAL']/$FORM['ROWS']);
	}
	EJE($RETURN);
}
elseif($ROUTE_OPC == 'Listado_Turnos'){
	$RETURN['COUNT'] = 0;
	$RETURN['TOTAL'] = 0;
	$RETURN['PAGINAS'] = 1;
	$RETURN['ROWS'] = [];
	if($PP['C'] != 1 || CIJE('CtU_ADVANCE')){EJE($RETURN);}
	$ARRAY_ORDER = array(1 => 'T.`fecha` DESC, T.`horario` DESC, CONCAT(C.`categoria`, " - ", A.`profesional`) ASC');
	$FORM = LISTADO_QUERY($ARRAY_ORDER);
	$SEARCH = "WHERE T.`id_persona`='".$sJ['CtU_ADVANCE']."' AND C.`id_categoria` IN (".implode(",", $PERMISOS_C).")";
	$Que = QuerySelect("SELECT T.`id_turno`,CONCAT(C.`categoria`, ' - ', A.`profesional`) AS 'turnera',T.`fecha`,T.`horario`,T.`motivo`,T.`estado`, T.`reg_usuario` FROM ".$DBT['TURNERAS_TURNOS']." T JOIN ".$DBT['TURNERAS_AGENDAS']." A ON T.`id_agenda`=A.`id_agenda` JOIN ".$DBT['TURNERAS_PARAM_CATEGORIAS']." C ON A.`id_categoria`=C.`id_categoria` ". $SEARCH." ORDER BY ".$FORM['ORDENAR']." LIMIT ".$FORM['LIMIT']." ,".$FORM['ROWS'],"QWE_PORTAL");
	while($Row = QueryFetch($Que)){
		$RETURN['COUNT']++;
		$TMP = [];
		$TMP['ID'] 						= $Row['id_turno'];
		$TMP['DATA']['TURNERA'] 		= $Row['turnera'];
		$TMP['DATA']['FECHA'] 			= Fecha_Formato($Row['fecha']);
		$TMP['DATA']['HORA']	 		= Hora_Formato($Row['horario']);
		$TMP['DATA']['ESTADO'] 			= Estados($Row['estado'], $Row['reg_usuario'],$Row['motivo']);
		array_push($RETURN['ROWS'], $TMP);
		unset($TMP);
	}
	$Que = QuerySelect("SELECT COUNT(*) AS 'total' FROM ".$DBT['TURNERAS_TURNOS']." T JOIN ".$DBT['TURNERAS_AGENDAS']." A ON T.`id_agenda`=A.`id_agenda` JOIN ".$DBT['TURNERAS_PARAM_CATEGORIAS']." C ON A.`id_categoria`=C.`id_categoria` ". $SEARCH, "QWE_PORTAL");
	while($Row = QueryFetch($Que)){	
		$RETURN['TOTAL'] = $Row['total'];
		$RETURN['PAGINAS'] = ceil($RETURN['TOTAL']/$FORM['ROWS']);
	}
	EJE($RETURN);
}
elseif($ROUTE_OPC == 'Listado_TurnosFecha'){
	$RETURN['COUNT'] = 0;
	$RETURN['TOTAL'] = 0;
	$RETURN['PAGINAS'] = 1;
	$RETURN['ROWS'] = [];
	$RETURN['TITLE'] = '';
	if($PP['C'] != 1 || CIJE('CJS_ADVANCE')){EJE($RETURN);}
	if(
		!array_key_exists('CET_ID_CATEGORIA',$sJ['CJS_ADVANCE']) || $sJ['CJS_ADVANCE']['CET_ID_CATEGORIA'] == '' || 
		!array_key_exists('CTS_PROFESIONAL',$sJ['CJS_ADVANCE']) || $sJ['CJS_ADVANCE']['CTS_PROFESIONAL'] == '' || 
